APP_DATA_DIR=data
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ASR_WORKER_CONCURRENCY=1
DATABASE_URL=sqlite:///data/ai_emr.sqlite3

# whisper: local faster-whisper transcription
# mock: no external ASR, returns sample transcript
ASR_PROVIDER=whisper
STREAM_ASR_PROVIDER=sherpa_onnx
SHERPA_MODEL_PATH=models/sherpa-onnx-streaming-paraformer-bilingual-zh-en
SHERPA_SAMPLE_RATE=16000
SHERPA_NUM_THREADS=2
VOSK_MODEL_PATH=models/vosk-model-small-cn-0.22
VOSK_SAMPLE_RATE=16000
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=
WHISPER_BEAM_SIZE=8
WHISPER_TEMPERATURE=0
WHISPER_NO_SPEECH_THRESHOLD=0.8
WHISPER_FALLBACK_MIN_CHARS=18
WHISPER_RETRY_ON_SHORT=true
WHISPER_VAD_MIN_SILENCE_MS=900
WHISPER_VAD_SPEECH_PAD_MS=450
ASR_AI_STANDARDIZE=false
ASR_AI_STANDARDIZE_TIMEOUT_SECONDS=3
ASR_AI_STANDARDIZE_MAX_CHARS=1500
ASR_STANDARDIZER_CONCURRENCY=2

# deepseek: use DeepSeek OpenAI-compatible Chat Completions JSON mode
# openai: use OpenAI Responses API Structured Outputs
# rules: deterministic fallback extraction for deployment smoke tests
LLM_PROVIDER=deepseek
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=
DEEPSEEK_TIMEOUT_SECONDS=20
EMR_MAX_TRANSCRIPT_CHARS=4500
